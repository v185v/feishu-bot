# GitHub Webhook Configuration
# Default webhook secret (can be overridden per repository in config)
GITHUB_WEBHOOK_SECRET=your-default-webhook-secret-here

# Configuration Source
# Options: "file" or "kv"
CONFIG_SOURCE=file

# File-based Configuration (when CONFIG_SOURCE=file)
CONFIG_PATH=./config/repositories.json

# KV-based Configuration (when CONFIG_SOURCE=kv)
# CONFIG_KV_NAMESPACE=github_bot_config

# Logging Configuration
# Options: "debug", "info", "warn", "error"
LOG_LEVEL=info

# Global Settings (optional - can be set in config file)
# RETRY_ATTEMPTS=3
# TIMEOUT_MS=5000
